# Postgres connection string — Supabase → Project Settings → Database → Connection string (URI).
# Port 6543 = transaction-mode pooler (the client sets prepare:false for this).
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-1-<region>.pooler.supabase.com:6543/postgres

# fonio — leave blank during development; set FONIO_LIVE=true only when ready for real calls
FONIO_API_KEY=
FONIO_FROM_NUMBER=
FONIO_AGENT_ID=
FONIO_LIVE=false

PORT=3000
CLINIC_LOCATION=HOIV Arsenalstraße 11, 1030 Wien

# Callback timing (ms) — shrink for demo, e.g. CALLBACK_RETRY_AFTER_MS=60000
CALLBACK_RETRY_AFTER_MS=900000
CALLBACK_EXPIRES_AFTER_MS=14400000
CALLBACK_POLL_INTERVAL_MS=30000
